# ============================================
# Nil Nil Server - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to Git - it's in .gitignore

# --- Football Data API ---
# Get this from: https://www.football-data.org/client/login
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# --- Apple Push Notifications (APNs) ---
# Get the .p8 file from: Apple Developer → Certificates → Keys → Create new key
# Enable "Apple Push Notifications service (APNs)" when creating the key
APN_KEY_ID=your_10_char_key_id_here
APN_TEAM_ID=6WY9675C6N
APN_BUNDLE_ID=com.nilnil.goalalarm

# The CONTENT of your .p8 file (copy the whole thing including BEGIN/END lines)
# In Railway/Render, paste the entire .p8 file content as a single env variable
# Replace newlines with \n when pasting as one line
APN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_content_here\n-----END PRIVATE KEY-----"

# --- Server Config ---
PORT=3000
NODE_ENV=development

# Set to "production" when deployed
# NODE_ENV=production
